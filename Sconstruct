import os

linker_script = os.path.join('config_bin.ld')

gcc_path = os.path.abspath(
    os.path.join(
        'toolchain',
        'mingw-w64-x86_64-arm-none-eabi',
        'bin',
    )
)

env = Environment(
    tools=['gcc', 'gnulink', 'ar'],
    CC=os.path.join(gcc_path, 'arm-none-eabi-gcc.exe'),
    AS=os.path.join(gcc_path, 'arm-none-eabi-as.exe'),
    AR=os.path.join(gcc_path, 'arm-none-eabi-ar.exe'),
    LINK=os.path.join(gcc_path, 'arm-none-eabi-gcc.exe'),
    OBJCOPY=os.path.join(gcc_path, 'arm-none-eabi-objcopy.exe'),
    OBJSUFFIX='.o',
    PROGSUFFIX='.elf',
)

env.Append(CCFLAGS=[
    '-mcpu=cortex-m4',
    '-mthumb',
    '-ffreestanding',
    '-fdata-sections',
    '-ffunction-sections',
])

env.Append(LINKFLAGS=[
    '-mcpu=cortex-m4',
    '-mthumb',
    '-nostdlib',
    '-nostartfiles',
    '-Wl,--gc-sections',
    '-T' + linker_script,
])

env.Replace(
    CCCOMSTR='CC      $SOURCE',
    LINKCOMSTR='LD      $TARGET',
    SHCCCOMSTR='SHCC    $SOURCE',
    SHCXXCOMSTR='SHCXX   $SOURCE',
    SHLINKCOMSTR='SHLD    $TARGET',
    COMPILATIONDB_COMSTR=None,
)

env.Append(CPPPATH=[
    '../Platform/Common',
    '../Platform/generated',
    '../McuLib/S32K3XX/BaseNXP_TS_T40D34M50I0R0/include',
    '../App/app_swi',
    '../App/app_swi/config'
    ])

cfg_obj = env.Object(
    target='build/obj/app_config.o',
    source='../App/app_config.c'
)

swi_obj = env.Object(
    target='build/obj/app_swi_config.o',
    source='../App/app_swi/config/app_swi_config.c'
)

elf = env.Program(target='build/app_config.elf', source=[cfg_obj, swi_obj])
bin_file = env.Command(
    'build/app_config.bin',
    elf,
    Action('$OBJCOPY -O binary $SOURCE $TARGET', 'OBJCOPY $SOURCE --> $TARGET')
)

# 默认生成bin文件, 直接在终端输入 scons 即可
Default(bin_file)

# 在终端输入 scons bin 可以生成bin文件。 目前多余了。
env.Alias('bin', bin_file)
